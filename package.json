{
  "name": "hybrid-harness",
  "version": "0.2.0",
  "description": "Hybrid harness that combines Ouroboros-style interviewing with a Ralph-style verification loop.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "harness": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "eval": "vitest run tests/eval-repo-aware.test.ts",
    "smoke:cli": "npm run build && node dist/cli.js --help",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
